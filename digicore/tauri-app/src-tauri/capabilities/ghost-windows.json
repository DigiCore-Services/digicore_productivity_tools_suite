{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "ghost-windows",
  "description": "Capabilities for Ghost Suggestor and Follower overlay windows",
  "windows": ["ghost-suggestor", "ghost-follower"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "positioner:default"
  ]
}

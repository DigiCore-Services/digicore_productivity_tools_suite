{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "ghost-windows",
  "description": "Capabilities for overlay and quick-search windows",
  "windows": ["ghost-suggestor", "ghost-follower", "quick-search", "variable-input"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-hide",
    "positioner:default"
  ]
}
